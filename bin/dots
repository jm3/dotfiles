#!/bin/sh
# The art of correct configuration.
# John Manoogian III * jm3 * 2013
#
# Polyglot sh/zsh: sh ensures zsh is installed then re-execs; zsh runs the rest.
if ! command -v zsh >/dev/null 2>&1; then
  if command -v apt-get >/dev/null 2>&1; then
    echo "Installing zsh..."; sudo apt-get install -y zsh
  elif command -v brew >/dev/null 2>&1; then
    echo "Installing zsh..."; brew install zsh
  else
    echo "zsh not found. Please install zsh and re-run." >&2; exit 1
  fi
fi
[ -n "$ZSH_VERSION" ] || exec zsh "$0" "$@"

# ── zsh from here ─────────────────────────────────────────────────────────────

setopt NULL_GLOB

DOTS="$HOME/.dotfiles"
FORCE=0
PERSONALIZE=1

# bootstrap mode: true when piped to zsh directly (e.g. curl | zsh)
[[ "${0:t}" == "zsh" ]] && BOOTSTRAP=1 || BOOTSTRAP=0

case "$(uname -s)" in
  Darwin*) OS=macosx ;;
  Linux*)  OS=linux  ;;
  *)       OS=unknown ;;
esac

# ── helpers ───────────────────────────────────────────────────────────────────

# rename file/dir to *.old to get it out of the way
bup() {
  local f=$1
  [[ -e $f || -L $f ]] || return
  [[ $f == */.ssh/config ]] || echo "Moving existing ${f:t} out of the way"
  if [[ -e "${f}.old" ]]; then
    rm -rf "/tmp/${f:t}"
    return
  fi
  mv "$f" "${f}.old"
}

assert_git() {
  command -v git >/dev/null 2>&1 && return
  echo "git not found — please install git and re-run." >&2
  exit 1
}

# print basenames of all installable entries under dots/
installable_dots() {
  local -a skip=(. .. .git .git-vars.tmpl .ssh_config osx .DS_Store)
  for f in "$DOTS"/dots/*(DN); do
    local base="${f:t}"
    [[ " ${skip[*]} " == *" $base "* ]] && continue
    [[ $base == *.swp ]] && continue
    print "$base"
  done
}

# symlink ~/dot → .dotfiles/dots/dot (relative, so portable if HOME moves)
make_symlink() {
  local dot=$1 target=".dotfiles/dots/$1" dest="$HOME/$1"
  [[ -L $dest && $(readlink "$dest") == "$target" ]] && return
  [[ -e $dest && ! -L $dest ]] && bup "$dest"
  [[ -L $dest ]] && rm "$dest"
  echo "Linking ~/$dot"
  ln -s "$target" "$dest"
}

# ── steps ─────────────────────────────────────────────────────────────────────

clone_repo() {
  assert_git
  if [[ -d "$HOME/.dotfiles/.git" ]]; then
    [[ $USER == jm3 ]] || git -C "$DOTS" pull
  else
    echo "Fetching dotfiles..."
    git clone "https://github.com/jm3/dotfiles.git" "$DOTS"
  fi
}

install_git_friendly() {
  command -v pull >/dev/null 2>&1 && return
  if [[ -d /usr/local && -w /usr/local ]]; then
    echo "Installing git-friendly"
    curl -sL "https://raw.github.com/jamiew/git-friendly/master/install.sh" | bash
  else
    echo "Skipping git-friendly: /usr/local not writable"
  fi
}

install_dotfiles() {
  while IFS= read -r dot; do
    make_symlink "$dot"
  done < <(installable_dots)
  link_bin
  setup_ssh_config
}

link_bin() {
  local dest="$HOME/bin" target=".dotfiles/bin"
  [[ -L $dest && $(readlink "$dest") == "$target" ]] && return
  [[ -d $dest && ! -L $dest ]] && bup "$dest"
  [[ -L $dest ]] && rm "$dest"
  ln -s "$target" "$dest"
}

setup_ssh_config() {
  local dest="$HOME/.ssh/config" target="$DOTS/dots/.ssh_config"
  mkdir -p "$HOME/.ssh"
  [[ -L $dest ]] && return
  [[ -e $dest ]] && bup "$dest"
  ln -s "$target" "$dest"
}

setup_vim() {
  mkdir -p "$HOME/.vim/backups"
}

personalize_git_env() {
  (( PERSONALIZE )) || return
  local vars_file="$HOME/.git-vars"

  if (( BOOTSTRAP )); then
    touch "$vars_file"
    return
  fi

  [[ -n $GIT_AUTHOR_NAME && -n $GIT_AUTHOR_EMAIL && -n $GITHUB_USER ]] && return

  print "
I'm going to set up your dotfiles for git. A few quick questions —
nothing is sent anywhere. Skip any prompt with <enter>.
"
  local git_name=$GIT_AUTHOR_NAME git_email=$GIT_AUTHOR_EMAIL github_user=$GITHUB_USER

  [[ -z $git_name    ]] && { print -n "Your full name:       "; read -r git_name    }
  [[ -z $git_email   ]] && { print -n "Your email:           "; read -r git_email   }
  [[ -z $github_user ]] && { print -n "Your GitHub username: "; read -r github_user }

  local tmp=$(mktemp)
  sed \
    -e "s/__GIT_NAME__/$git_name/" \
    -e "s/__GIT_EMAIL__/$git_email/" \
    -e "s/__GITHUB_USER__/$github_user/" \
    "$DOTS/dots/.git-vars.tmpl" > "$tmp"
  mv "$tmp" "$vars_file"

  print "\nIf anything looks off, edit ~/.git-vars directly."
  cat "$vars_file"
  print "\nAll set! To finish, run: source ~/.git-vars"
}

install_osx_goodies() {
  [[ $OS == macosx ]] || return
  setup_iterm
  setup_sublime_text 2
  setup_sublime_text 3
}

setup_iterm() {
  [[ -d /Applications/iTerm.app ]] || return
  local plist="com.googlecode.iterm2.plist"
  local iterm_cfg="$HOME/Library/Preferences/$plist"
  local repo_plist="$DOTS/osx/iterm/$plist"

  diff -q "$iterm_cfg" "$repo_plist" >/dev/null 2>&1 && return

  [[ -f $iterm_cfg ]] && bup "$iterm_cfg"
  rm -rf "$iterm_cfg"
  git -C "$DOTS/osx/iterm" checkout "$plist"

  local orig="${repo_plist}.orig"
  cp "$repo_plist" "$orig"
  echo "Personalizing iTerm preferences"
  plutil -convert xml1 -o /dev/stdout "$orig" \
    | sed "s/jm3/$USER/g" \
    | plutil -convert binary1 -o "$repo_plist" -
  rm -f "$orig"

  echo "Linking iTerm preferences (hard link)"
  ln "$repo_plist" "$iterm_cfg"
}

setup_sublime_text() {
  local version=$1
  [[ -d "/Applications/Sublime Text ${version}.app" ]] || return
  local subl_dir="$HOME/Library/Application Support/Sublime Text ${version}/Packages"
  local dest="$subl_dir/User" target="$DOTS/osx/st${version}"
  mkdir -p "$subl_dir"
  [[ -L $dest && $(readlink "$dest") == "$target" ]] && return
  if [[ -d $dest && ! -L $dest ]]; then
    [[ -f "$subl_dir/old-configs.tgz" ]] && mv "$subl_dir/old-configs.tgz" /tmp/
    echo "Archiving old Sublime Text $version configs"
    tar czf "$subl_dir/old-configs.tgz" -C "$subl_dir" User
  fi
  rm -rf "$dest"
  echo "Linking Sublime Text $version configs"
  ln -s "$target" "$dest"
}

ensure_zsh() {
  [[ $SHELL == */zsh ]] && return
  echo "Your shell is not Zsh — you're missing some cool features."
  local zsh_path=$(command -v zsh)
  if [[ -z $zsh_path ]]; then
    command -v brew >/dev/null 2>&1 \
      && echo "Install with: brew install zsh" \
      || echo "Install with: sudo apt-get install zsh"
  else
    echo "To switch: chsh -s $zsh_path"
  fi
}

uninstall_dotfiles() {
  while IFS= read -r dot; do
    local dest="$HOME/$dot" target=".dotfiles/dots/$dot"
    if [[ -L $dest && $(readlink "$dest") == "$target" ]]; then
      echo "Removing ~/$dot"
      rm "$dest"
    fi
  done < <(installable_dots)
  for f in "$HOME/.git-vars" "$HOME/.zcompdump"; do
    [[ -f $f ]] && { echo "Removing ${f:t}"; mv "$f" /tmp/; }
  done
  [[ -L "$HOME/.ssh/config" ]] && rm "$HOME/.ssh/config"
}

display_instructions() {
  (( BOOTSTRAP )) || return
  echo 'Run this command to complete setup: ~/bin/dots'
}

# ── main ──────────────────────────────────────────────────────────────────────

while [[ $# -gt 0 ]]; do
  case "$1" in
    -f|--force)           FORCE=1 ;;
    -u|--uninstall)       uninstall_dotfiles; exit ;;
    -n|--no-personalize)  PERSONALIZE=0 ;;
    *) echo "Unknown option: $1" >&2 ;;
  esac
  shift
done

clone_repo
install_git_friendly
install_dotfiles
personalize_git_env
install_osx_goodies
setup_vim
ensure_zsh
display_instructions
